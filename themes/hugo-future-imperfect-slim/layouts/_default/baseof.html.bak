<!doctype html>
<html lang="{{ .Page.Language | default "en" }}">
  {{ partial "head" . }}
  <body>
    {{ partial "site-header" . }}
    <div id="wrapper">
      {{ partial "site-intro" . }}
      <main id="site-main">
        {{ block "main" . }}{{ end }}
      </main>
      {{ partial "site-sidebar" . }}
      {{ partial "site-footer" . }}
      {{ partial "scripts" . }}
    </div>
    
    <div class="footer">
      <p>
        {{ (.Site.Copyright | safeHTML) | default (print " - van den <span class="bold-rotate">B</span>oom \u00A9 " now.Year "  -  ") }}      
      </p>
    </div>

  </body>
</html>
